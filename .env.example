NODE_ENV=development
APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

DB_HOST=localhost
DB_PORT=3306
DB_USER=donate_app_user
DB_PASSWORD=change-me
DB_NAME=donate_platform
DB_SSL=false

NEXTAUTH_SECRET=change-me-generate-at-least-32-characters

MIDTRANS_SERVER_KEY=change-me-midtrans-server-key
MIDTRANS_IS_PRODUCTION=false

