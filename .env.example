# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_USERNAME=default
# REDIS_PASSWORD=
# REDIS_TLS=false
ALLOWED_ORIGINS=http://localhost:3000
API_KEY=change-me-api-key
